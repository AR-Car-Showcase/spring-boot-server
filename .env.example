SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/car_data
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
JWT_SECRET=change-me-to-a-long-random-secret

SECURITY_REFRESH_STORE_MODE=REDIS
SECURITY_REFRESH_REDIS_KEY_PREFIX=security:refresh
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_SSL_ENABLED=false

APP_SIGNUP_VERIFICATION_ENABLED=true
APP_SIGNUP_VERIFICATION_STORE_MODE=REDIS
APP_SIGNUP_VERIFICATION_REDIS_KEY_PREFIX=security:signup-verification
APP_SIGNUP_VERIFICATION_SMTP_ENABLED=true
APP_SIGNUP_VERIFICATION_FROM_ADDRESS=no-reply@arcarshowcase.com
APP_SIGNUP_DISPOSABLE_EMAIL_DOMAINS=mailinator.com,10minutemail.com,tempmail.com,yopmail.com

APP_PASSWORD_RESET_ENABLED=true
APP_PASSWORD_RESET_STORE_MODE=REDIS
APP_PASSWORD_RESET_REDIS_KEY_PREFIX=security:password-reset
APP_PASSWORD_RESET_SMTP_ENABLED=true
APP_PASSWORD_RESET_FROM_ADDRESS=no-reply@arcarshowcase.com

SECURITY_GOOGLE_ENABLED=true
SECURITY_GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com
SECURITY_GOOGLE_ISSUER_URI=https://accounts.google.com
SECURITY_GOOGLE_AUTO_LINK_BY_EMAIL=true

APP_CORS_ALLOWED_ORIGINS=http://localhost:8081

# Model Asset Configuration (for CDN/Object Storage)
APP_MODELS_STATIC_BASE_URL=/api/static/models
APP_MODELS_STATIC_VERSION=
APP_MODELS_GENERATED_BASE_URL=/api/models
APP_MODELS_GENERATED_VERSION=

APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_MODEL_CAPACITY=8
APP_RATE_LIMIT_MODEL_REFILL_PER_MINUTE=8
